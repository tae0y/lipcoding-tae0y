# 백엔드 환경변수 샘플 — 실제 값으로 채워 `backend/.env`로 복사해 쓰세요.
#   cp .env.example .env
# `.env`는 .gitignore로 제외되므로 시크릿/엔드포인트는 커밋되지 않습니다.
# 이 파일에는 절대 실제 키/엔드포인트를 넣지 마세요 (플레이스홀더만).

# ── Azure OpenAI (BYOK) ───────────────────────────────────────────────────────
# Azure AI Foundry / Azure OpenAI 리소스의 엔드포인트 호스트 (끝 슬래시 포함 가능)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# 리소스 API 키 (시크릿 — 커밋 금지)
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
# 배포(deployment) 이름 = 모델 호출 시 사용하는 이름 (예: gpt-4o, gpt-4.1-mini)
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
# API 버전
AZURE_OPENAI_API_VERSION=2024-10-21

# ── 동작 토글 ─────────────────────────────────────────────────────────────────
# 1로 두면 Copilot SDK 호출을 건너뛰고 휴리스틱 폴백만 사용 (오프라인/테스트용)
SKIP_COPILOT_SDK=0

# ── 앱 설정 (선택) ────────────────────────────────────────────────────────────
# SQLite 파일 경로 (배포 시 Azure Files 볼륨에 마운트)
APP_DB_PATH=./data/app.db
# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
